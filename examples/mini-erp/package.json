{
  "name": "@erpforge/mini-erp-example",
  "version": "0.1.0",
  "description": "ERPForge 示例项目 — 跨境电商 Mini ERP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
